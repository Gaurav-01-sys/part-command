# --- Claude (required for the AI query tab) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-5

# --- NVIDIA NIM (optional alternative for AI query tab) ---
NVIDIA_API_KEY="your-nvidia-api-key"
NVIDIA_MODEL=meta/llama3-70b-instruct

# --- Groq (optional alternative for AI query tab, via LangChain's ChatGroq) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=qwen/qwen3.6-27b

# --- EULER live tool access via Anthropic's MCP connector ---
# EULER_MCP_TOKEN is now auto-managed by the in-app OAuth flow.
# You can still set it manually here as a fallback for testing,
# but the EULER Connect tab (Tab 8) is the recommended approach.
EULER_MCP_URL=https://mcp.eulerapp.com/mcp
EULER_MCP_TOKEN=

# --- EULER OAuth 2.1 settings ---
# Redirect URI for the OAuth callback. Change this for production deployments.
# Local dev default: http://localhost:7860/euler-callback
EULER_REDIRECT_URI=http://localhost:7860/euler-callback

# Path where the encrypted OAuth token is persisted across restarts.
# Default: .euler_token in the project root (auto-created).
# Set to empty string to disable file persistence.
EULER_TOKEN_FILE=

# Optional secret used to XOR-encrypt the token file.
# Defaults to a machine-specific value if not set.
# Set this in production to a stable, random secret string.
EULER_TOKEN_SECRET=

# --- EULER live data via REST (optional, separate from the MCP tools above) ---
# Leave EULER_API_KEY blank to disable REST enrichment; no local or synthetic data is used.
EULER_API_BASE=https://api.eulerapp.com/v1
EULER_API_KEY=

# --- Elasticsearch (optional — enables ElasticRAG retrieval layer) ---
# Option A – local Docker (free):
#   docker run -d --name es -p 9200:9200 \
#     -e "discovery.type=single-node" \
#     -e "xpack.security.enabled=false" \
#     docker.elastic.co/elasticsearch/elasticsearch:8.13.0
# Option B – Elastic Cloud: set ES_URL to your Cloud endpoint and ES_API_KEY
# Leave ES_URL blank to disable ElasticRAG (app falls back to EULER MCP only).
ES_URL=http://localhost:9200
ES_API_KEY=
ES_INDEX=euler-partners
